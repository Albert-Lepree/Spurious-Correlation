# Databricks
DATABRICKS_SERVER_HOSTNAME=your-workspace.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_TOKEN=your-databricks-token

# PostgreSQL
db_user=your_pg_user
db_pass=your_pg_password
DB_HOST=localhost
DB_NAME=spuriousCorrelationdb

# vLLM server
VLLM_URL=http://localhost:8001/v1/completions
VLLM_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B-BF16

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Databricks ingestion date range
DATABRICKS_END_DATE=2026-03-15
